# cc-digest configuration

# Path to Claude Code projects directory
# Default: ~/.claude/projects
# CLAUDE_PROJECTS_DIR=~/.claude/projects

# Your display name in session transcripts (replaces "user" role)
# USER_DISPLAY_NAME=User

# Storage backend: sqlite (default) or mongo
# STORAGE_BACKEND=sqlite

# SQLite database path (only if STORAGE_BACKEND=sqlite)
# Default: ~/.local/share/cc-digest/cc-digest.db
# SQLITE_PATH=~/.local/share/cc-digest/cc-digest.db

# MongoDB connection (only if STORAGE_BACKEND=mongo)
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB=claude_sessions

# Ollama endpoint for digest & embeddings
# OLLAMA_URL=http://localhost:11434
# DIGEST_MODEL=qwen3:14b
# EMBED_MODEL=nomic-embed-text

# Comma-separated parent directories that contain your projects
# Used to infer project names from cwd paths
# PROJECT_ROOTS=Projects,Proyectos,dev,workspace,repos,src

# Minimum messages to include a session
# MIN_MESSAGES=4
